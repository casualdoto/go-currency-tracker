TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Auth service database (postgres-auth, port 5432)
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password
AUTH_DB_NAME=auth_db
AUTH_DB_SSLMODE=disable

# History service database (postgres-history, port 5433)
HISTORY_DB_HOST=localhost
HISTORY_DB_PORT=5433
HISTORY_DB_USER=history_user
HISTORY_DB_PASSWORD=history_password
HISTORY_DB_NAME=history_db
HISTORY_DB_SSLMODE=disable

# JWT
JWT_SECRET=supersecretjwtkey

# Kafka
KAFKA_BROKERS=localhost:9092

# Redis
REDIS_ADDR=localhost:6379

# CBR API
CBR_BASE_URL=https://www.cbr-xml-daily.ru

# Service ports
AUTH_SERVICE_PORT=8082
HISTORY_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
API_GATEWAY_PORT=8080
